# Server Configuration
LISTEN=127.0.0.1
PORT=18787
SITE_NAME="Soga Panel"
SITE_URL="http://localhost:8848"

# Database Configuration (MySQL/MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=soga_panel
DB_CONNECTION_LIMIT=10
DB_TIMEZONE="+08:00"

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX="soga:"

# Security
JWT_SECRET="your_jwt_secret_key"
TWO_FACTOR_SECRET_KEY="your_2fa_encryption_secret"
NODE_API_KEY="your_node_webapi_key"

# Payment System Configuration
# Channel providers: epay / epusdt / none
PAYMENT_ALIPAY="epay"
PAYMENT_WXPAY="epay"
PAYMENT_CRYPTO="epusdt"

# Epay Configuration
EPAY_PID="1001"
EPAY_KEY="your_epay_key"
EPAY_API_URL="https://pay.example.com"
EPAY_NOTIFY_URL="http://your-api.com/api/payment/notify"
EPAY_RETURN_URL="http://your-frontend.com/#/user/wallet"
# Payment Mode: redirect (Standard redirect) or api (API mode for QR codes)
EPAY_PAYMENT_MODE="api"

# Epusdt Configuration
EPUSDT_TOKEN="your_epusdt_token"
EPUSDT_API_URL="http://localhost:9000"
EPUSDT_NOTIFY_URL="http://your-api.com/api/payment/callback"
EPUSDT_RETURN_URL="http://your-frontend.com/#/user/wallet"
EPUSDT_TRADE_TYPE="usdt.trc20"
EPUSDT_TIMEOUT=900

# Mail Configuration
# Providers: resend / sendgrid / smtp / cloudflare / none
MAIL_PROVIDER="none"
MAIL_FROM="no-reply@yourdomain.com"

# SMTP (If MAIL_PROVIDER="smtp")
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER=""
SMTP_PASS=""
SMTP_SECURE="true"
SMTP_STARTTLS="false"
SMTP_AUTH_TYPE="login"

# Cloudflare Email Sending REST API (If MAIL_PROVIDER="cloudflare")
# 通过 Cloudflare REST API 发送邮件。MAIL_FROM 必须使用已接入 Email Sending 的域名邮箱：
#   npx wrangler email sending enable <你的域名>
# API 令牌需具备 "Email Sending: Edit" 权限。
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_EMAIL_API_TOKEN=""

# 亦可通过 Cloudflare SMTP 中继发送（复用上面的 smtp provider，仅需如下配置）：
#   MAIL_PROVIDER="smtp"
#   SMTP_HOST="smtp.mx.cloudflare.net"
#   SMTP_PORT=465
#   SMTP_SECURE="true"        # 仅支持 465 隐式 TLS
#   SMTP_USER="api_token"     # 固定字面量 api_token
#   SMTP_PASS="<Cloudflare API 令牌>"

# OAuth (Optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI=""

# Passkey (WebAuthn)
PASSKEY_RP_ID="localhost"
PASSKEY_ORIGIN="http://localhost:8848"
